# AEGIS Backend Environment Variables

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
CRUNCHBASE_API_KEY=your_crunchbase_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aegis_db
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# ML Models
SURVIVAL_PREDICTOR_MODEL_PATH=ml_models/survival_predictor.pkl
LOGISTICS_MODEL_PATH=ml_models/logistics_model.pkl
WORKFORCE_MODEL_PATH=ml_models/workforce_model.pkl

# API Configuration
GEMINI_REQUESTS_PER_DAY=1500
GEMINI_TOKENS_PER_DAY=1000000

# Features
ENABLE_CACHING=True
ENABLE_ML_FEATURES=True

# Deployment
DEBUG=False
ENVIRONMENT=development
